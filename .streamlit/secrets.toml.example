# Copy this file to secrets.toml (locally) OR paste contents into the
# Streamlit Community Cloud → Secrets editor.
#
# The actual secrets.toml is gitignored — never commit your real keys.

# Anthropic Claude API — enables Copy Studio, classifier, brand reports,
# image prompts, landing pages, receipt OCR, FDA-compliance LLM pass
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: lock the cloud app behind a simple shared password
# Visitors must enter this in a login screen before seeing the dashboard.
# Comment out if you want public access.
# APP_PASSWORD = "your-shared-team-password"

# Optional: tag this deployment so the UI shows where it's running
# (useful if you have prod / staging clouds)
# DEPLOYMENT_LABEL = "production"
